---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = "Amazon DD+7 Payout Help",
  description = "Amazon DD+7 payout delay, reserve hold, and arbitration resource.",
  canonical = new URL(Astro.url.pathname, 'https://amazondd7.com').href
