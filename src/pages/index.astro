    max-width: 800px;
    margin: 0 auto;
  }
  .solution-text {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--c-blue-primary);
    margin-top: 2rem;
    padding-left: 1.5rem;
    border-left: 4px solid var(--c-blue-primary);
  }

  /* Benefits */
