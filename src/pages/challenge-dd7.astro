</Layout>

<style>
  .hero {
    padding: 6rem 0 4rem;
    background: linear-gradient(135deg, var(--c-black) 0%, var(--c-blue-dark) 100%);
  }

  /* Reuse some critical styles directly here for grid items that aren't global */
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 2rem;
  }
  .benefit-card {
    grid-column: span 2;
    background: var(--c-white);
    padding: 2.5rem;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    text-align: center;
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  /* Offset the 4th and 5th items to perfectly center them on the second row */
  .benefit-card:nth-child(4) {
    grid-column: 2 / span 2;
  }
  .benefit-card:nth-child(5) {
    grid-column: 4 / span 2;
  }
  .benefit-card:hover { transform: translateY(-5px); }
  .b-icon { font-size: 3rem; margin-bottom: 1rem; }
  .benefit-card h3 { font-size: 1.35rem; margin-bottom: 0.75rem; color: var(--c-black); }
  .benefit-card p { color: var(--c-gray-600); font-size: 1.05rem; margin: 0; }

  @media (max-width: 900px) {
    .benefits-grid {
      grid-template-columns: 1fr !important;
    }
    .benefit-card {
      grid-column: auto !important;
    }
    .dual-panel, .strategy-content, .pricing-grid {
      grid-template-columns: 1fr !important;
      gap: 2rem !important;
    }
    .hero-content h1 { font-size: 2.25rem !important; }
    .hero-ctas { flex-direction: column; }
  }
</style>
