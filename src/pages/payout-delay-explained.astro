</Layout>

<style>
  .article-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .article-container h2 {
    margin-top: 3rem;
    font-size: 2rem;
    color: var(--c-blue-dark);
    margin-bottom: 1.5rem;
  }

  .article-container h3 {
    font-size: 1.35rem;
    color: var(--c-black);
    margin-bottom: 0.75rem;
  }

  .article-container p {
